# Environment variables for cluster configuration during tests.

# Number of nodes in the cluster. The threshold and participant count are 
# derived from this value (all-n).
NODE_COUNT=

# Controller configuration.
CONTROLLER_HOST=
CONTROLLER_PORT=
CONTROLLER_TOKEN=

# Nodes configuration.
# Port for node 1. Subsequent nodes use base+1, base+2, etc.
NODE_BASE_PORT=
# Token prefix. Node N gets "<prefix><N>", e.g. prefix "" → "1", "2", "3".
NODE_BASE_TOKEN=

# Vault configuration.
VAULT_ADDRESS=
VAULT_MOUNT=
VAULT_PREFIX=
VAULT_FIELD=
VAULT_TOKEN=
# Optional Vault namespace for Enterprise.
# VAULT_NAMESPACE=
